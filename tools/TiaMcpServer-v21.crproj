<project outputDir="..\..\..\..\..\release\obfuscated-v21" baseDir="." xmlns="http://confuser.codeplex.com">

  <module path="TiaMcpServer.exe">
    <rule pattern="true" inherit="false">
      <protection id="rename" action="add" />
      <protection id="ctrl flow" action="add" />
      <protection id="anti debug" action="add" />
      <protection id="anti ildasm" action="add" />
      <protection id="resources" action="add" />
    </rule>
    <rule pattern="full-name('McpServer')" inherit="false">
      <protection id="rename" action="remove" />
    </rule>
    <rule pattern="full-name('Program')" inherit="false">
      <protection id="rename" action="remove" />
    </rule>
    <rule pattern="full-name('CliOptions')" inherit="false">
      <protection id="rename" action="remove" />
    </rule>
  </module>

</project>
