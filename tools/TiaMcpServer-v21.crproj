<project outputDir="..\..\..\..\..\release\obfuscated-v21" baseDir="." xmlns="http://confuser.codeplex.com">

  <module path="TiaMcpServer.exe">
    <!-- ctrl flow + anti debug only. No rename — property names must stay for JSON serialization -->
    <rule pattern="true" inherit="false">
      <protection id="ctrl flow" action="add" />
      <protection id="anti debug" action="add" />
    </rule>
  </module>

</project>
