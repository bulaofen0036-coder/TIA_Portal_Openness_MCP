{
  "kind": "fb",
  "tool": "PlcBuildAndImport",
  "description": "通用启用/停止/故障/复位保持块，只表达基础布尔逻辑。",
  "json": {
    "blockName": "FB_BasicLatch",
    "blockNumber": 110,
    "inputs": [
      { "name": "Enable", "datatype": "Bool" },
      { "name": "Disable", "datatype": "Bool" },
      { "name": "FaultInput", "datatype": "Bool" },
      { "name": "Reset", "datatype": "Bool" }
    ],
    "outputs": [
      { "name": "Active", "datatype": "Bool" },
      { "name": "Fault", "datatype": "Bool" }
    ],
    "statics": [
      { "name": "ActiveLatch", "datatype": "Bool" },
      { "name": "FaultLatch", "datatype": "Bool" }
    ],
    "structuredText": {
      "operations": [
        { "op": "if", "condition": "FaultInput" },
        { "op": "assignment", "target": "FaultLatch", "literalValue": "TRUE", "indent": 1 },
        { "op": "assignment", "target": "ActiveLatch", "literalValue": "FALSE", "indent": 1 },
        { "op": "elsif", "condition": "Reset" },
        { "op": "assignment", "target": "FaultLatch", "literalValue": "FALSE", "indent": 1 },
        { "op": "endif" },
        { "op": "if", "condition": "Disable OR FaultLatch" },
        { "op": "assignment", "target": "ActiveLatch", "literalValue": "FALSE", "indent": 1 },
        { "op": "elsif", "condition": "Enable AND NOT FaultLatch" },
        { "op": "assignment", "target": "ActiveLatch", "literalValue": "TRUE", "indent": 1 },
        { "op": "endif" },
        { "op": "assignment", "target": "Active", "source": "ActiveLatch" },
        { "op": "assignment", "target": "Fault", "source": "FaultLatch" }
      ]
    }
  }
}

